# Database
DATABASE_URL=mysql://user:password@hostname:3306/database_name

# Node environment
NODE_ENV=production

# JWT / Cookies
JWT_SECRET=your-secure-jwt-secret-min-32-characters

# Stripe Payment Processing
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Optional: OAuth (if using OAuth)
OAUTH_SERVER_URL=https://your-oauth-server
OWNER_OPEN_ID=your-owner-open-id

# Optional: Vite frontend env vars
VITE_APP_ID=mr-todds-woodcrafts
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional: File uploads (AWS S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name

# Optional: Analytics
VITE_ANALYTICS_ENDPOINT=https://your-analytics-endpoint
VITE_ANALYTICS_WEBSITE_ID=your-website-id
