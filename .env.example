# MySQL connection (required for orders, products, contact form, admin)
DATABASE_URL=

# Session signing (required in production)
JWT_SECRET=

# Public storefront — override when using a staging URL
VITE_PUBLIC_SITE_URL=https://mrtoddsworkshop.com

# Venmo username (no @) — shows a profile link on checkout and contact when set
VITE_VENMO_HANDLE=

# Optional: Umami analytics (both required to enable the snippet)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# OAuth / admin (set per your hosting provider)
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
