# Mr. Todd's Woodcrafts - Environment Variables
# Copy this file to .env and fill in the values

# MySQL database connection string
DATABASE_URL=mysql://user:password@localhost:3306/mrtodds

# Secret used to sign admin session cookies (generate a random string)
JWT_SECRET=change-me-to-a-random-secret-string

# Password for the /api/admin/login page
ADMIN_PASSWORD=change-me-to-a-secure-password

# Unique identifier for the admin user (can be any string)
OWNER_OPEN_ID=admin-owner

# Server port (optional, defaults to 3000)
PORT=3000

# Directory for uploaded images (optional, defaults to ./uploads)
# UPLOADS_DIR=/path/to/uploads
