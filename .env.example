# ─── App ──────────────────────────────────────────────────────────────────────
# Set NODE_ENV=production when running in production
NODE_ENV=development

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/mr_todds_woodcrafts

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Random secret for signing session JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_32_byte_hex_string

# The OAuth sub/openId of the admin account (Todd's login)
# After first login, check the users table to find your openId
OWNER_OPEN_ID=your_open_id_here

# OAuth provider URL (used by the built-in Manus auth system)
OAUTH_SERVER_URL=https://auth.manus.computer

# ─── Payments — Venmo ─────────────────────────────────────────────────────────
# Your Venmo username (without the @). Customers will send payment here.
# Example: if your Venmo is @mrtodds-woodcrafts, put: mrtodds-woodcrafts
VENMO_USERNAME=your-venmo-username

# ─── Vite / Frontend env ──────────────────────────────────────────────────────
# App ID used by Manus runtime (leave blank if self-hosting without Manus)
VITE_APP_ID=

# Your Venmo username — also needed by the frontend for the "Pay on Venmo" button
VITE_VENMO_USERNAME=your-venmo-username

# ─── AWS S3 (for product image uploads) ───────────────────────────────────────
# Only required if you want the admin image upload feature to work
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ─── Server port (optional, defaults to 3000) ─────────────────────────────────
PORT=3000
