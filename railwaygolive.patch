+            <h1
+              className="text-[#F5F0EB] text-3xl font-cinzel"
+              style={{ fontFamily: "Cinzel, serif" }}
+            >
+              Mr. Todd's Woodcrafts
+            </h1>
+          </div>
+
+          {/* Product */}
+          {product ? (
