+    list: adminProcedure.query(() => getSubscribers()),
+  }),
+
+  // ─── Cart (session-based, no login required) ──────────────────────────────
+  cart: router({
+    get: publicProcedure
+      .input(z.object({ sessionId: z.string() }))
+      .query(async ({ input }) => {
+        const session = await getCartSession(input.sessionId);
